generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BookingType {
  guest
  logged_in
  staff
  premium
}

enum ReservationStatus {
  confirmed
  cancelled
  seated
  completed
}

model Restaurant {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  timezone     String        @default("UTC")
  tables       Table[]
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Table {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  capacity     Int
  isActive     Boolean       @default(true)
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([restaurantId, name])
}

model Reservation {
  id            String            @id @default(cuid())
  restaurantId  String
  tableId       String
  restaurant    Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table         Table             @relation(fields: [tableId], references: [id], onDelete: Restrict)
  bookingType   BookingType
  status        ReservationStatus @default(confirmed)
  guestName     String
  guestEmail    String
  partySize     Int
  reservationAt DateTime
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([restaurantId, reservationAt])
  @@index([tableId, reservationAt])
}


model DailyKpiSnapshot {
  id                   String   @id @default(cuid())
  restaurantId         String
  restaurant           Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date                 DateTime
  totalReservations    Int
  confirmedCount       Int
  seatedCount          Int
  completedCount       Int
  cancelledCount       Int
  noShowCount          Int      @default(0)
  avgPartySize         Float
  bookingTypeBreakdown Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([restaurantId, date])
  @@index([restaurantId, date])
}
